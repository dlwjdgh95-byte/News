# Copy to .env (gitignored) for local runs, or set these as GitHub Actions
# repository secrets for the scheduled workflow. NEVER commit real values.

# --- Required (even the fallback needs these to deliver) ---
TELEGRAM_BOT_TOKEN=          # @realneeewsbot bot token from @BotFather
TELEGRAM_CHAT_ID=            # target chat/channel id

# --- Source B (economy). Optional: falls back to Guardian / Google News RSS ---
NEWSDATA_API_KEY=            # https://newsdata.io free tier (200 credits/day)

# --- Optional quality boosts ---
GUARDIAN_API_KEY=            # https://open-platform.theguardian.com (free dev key)
ANTHROPIC_API_KEY=          # enables 1-call LLM selection + 1-call summary
ANTHROPIC_MODEL=claude-sonnet-4-6   # stable subscribed model (avoid free-tier 429s)
